{
  "name": "@the-gridai/grid-sdk",
  "version": "0.1.0",
  "description": "Grid Exchange SDK - TypeScript client for the Grid trading platform",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.ts'",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "grid",
    "trading",
    "sdk",
    "api",
    "exchange",
    "ai",
    "inference",
    "websocket"
  ],
  "author": "The Grid",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/the-gridai/grid-cli.git",
    "directory": "grid/packages/sdk-typescript"
  },
  "bugs": {
    "url": "https://github.com/the-gridai/grid-cli/issues"
  },
  "homepage": "https://github.com/the-gridai/grid-cli#readme",
  "dependencies": {
    "axios": "^1.18.1",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "ws": "^8.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
