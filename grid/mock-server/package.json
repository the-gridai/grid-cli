{
  "name": "@the-gridai/grid-mock-server",
  "version": "0.1.0",
  "description": "Mock server for Grid SDK development and testing",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "grid-mock-server": "./dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.ts'",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "grid",
    "mock-server",
    "testing",
    "sdk"
  ],
  "author": "The Grid",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/the-gridai/grid-cli.git",
    "directory": "grid/mock-server"
  },
  "dependencies": {
    "express": "^5.2.1",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "uuid": "^14.0.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.6.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.12.0"
  }
}
