# Grid CLI environment configuration
# Copy to .env and fill in your values. Profiles (grid profile set) are the
# recommended alternative — see README.md "Configuration".

# API endpoints
API_URL=https://trading.api.thegrid.ai/v1
WS_URL=wss://trading.api.thegrid.ai/v1/
CONSUMPTION_API_URL=https://api.thegrid.ai/v1

# Ed25519 signing credentials (Trading API)
SIGNING_KEY=your-base64-encoded-ed25519-seed
SIGNING_KEY_FINGERPRINT=your-key-fingerprint

# Consumption (inference) API key — optional
# GRID_CLI_CONSUMPTION_KEY=

# Logging
LOG_LEVEL=info

# Optional: OpenTelemetry tracing
# GRID_TRACING_ENABLED=true
# GRID_OTEL_ENDPOINT=http://localhost:4318

# Optional: Sentry error tracking
# SENTRY_DSN=
