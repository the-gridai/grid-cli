{
  "name": "grid-cli",
  "version": "0.11.1",
  "description": "CLI and TypeScript SDK for trading on The Grid exchange",
  "type": "module",
  "main": "dist/src/sdk/index.js",
  "types": "dist/src/sdk/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/sdk/index.js",
      "types": "./dist/src/sdk/index.d.ts"
    },
    "./sdk": {
      "import": "./dist/src/sdk/index.js",
      "types": "./dist/src/sdk/index.d.ts"
    }
  },
  "bin": {
    "grid": "./bin/grid"
  },
  "scripts": {
    "build": "tsc && tsc-alias -f && npm run postbuild",
    "build:ci": "tsc && tsc-alias -f",
    "postbuild": "node scripts/postbuild.cjs",
    "bundle": "esbuild dist/src/cli/index.js --bundle --platform=node --target=node20 --outfile=dist/bundle/cli.mjs --format=esm --external:better-sqlite3 --external:ink --external:react --external:yoga-layout --banner:js='import { createRequire } from \"module\"; const require = createRequire(import.meta.url);'",
    "watch": "tsc --watch",
    "start": "node --require ./dist/src/instrumentation.cjs dist/src/cli/index.js",
    "dev": "ts-node src/cli/index.ts",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "test:strategies": "jest tests/unit/strategies --coverage",
    "test:persistence": "jest tests/unit/core/persistence --coverage",
    "test:property": "jest --testMatch '**/*.property.test.ts'",
    "type-check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts' 'strategies/**/*.ts' 'tests/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'strategies/**/*.ts' 'tests/**/*.ts' --fix",
    "prepush": "npm run lint && npm run typecheck && npm test"
  },
  "keywords": [
    "cli",
    "sdk",
    "trading",
    "exchange",
    "inference",
    "grid"
  ],
  "author": "The Grid",
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/instrumentation-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@sentry/node": "^10.38.0",
    "axios": "~1.13.6",
    "better-sqlite3": "^9.4.0",
    "chalk": "^4.1.2",
    "commander": "^14.0.2",
    "conf": "^10.2.0",
    "cron-parser": "^5.6.1",
    "dotenv": "^16.3.1",
    "ink": "^6.6.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "node-cron": "^4.2.1",
    "pg": "^8.16.3",
    "react": "^19.2.7",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "uuid": "^13.0.0",
    "winston": "^3.11.0",
    "ws": "^8.14.2",
    "zod": "^4.3.6"
  },
  "pkg": {
    "bin": "dist/src/cli/index.js",
    "scripts": "dist/**/*.js",
    "assets": [
      "package.json"
    ],
    "targets": [
      "node20-linux-x64",
      "node20-linux-arm64",
      "node20-macos-x64",
      "node20-macos-arm64",
      "node20-win-x64"
    ],
    "outputPath": "dist/bin"
  },
  "overrides": {
    "axios": "~1.13.6",
    "string-width": "4.2.3"
  },
  "devDependencies": {
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@types/better-sqlite3": "^7.6.9",
    "@types/jest": "^29.5.5",
    "@types/node": "^25.1.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.63.0",
    "@yao-pkg/pkg": "^5.16.1",
    "axios-mock-adapter": "^2.1.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "fast-check": "^4.5.3",
    "ink-testing-library": "^2.1.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "tsc-alias": "^1.8.17",
    "typescript": "^5.2.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/the-gridai/grid-cli.git"
  },
  "bugs": {
    "url": "https://github.com/the-gridai/grid-cli/issues"
  },
  "homepage": "https://github.com/the-gridai/grid-cli#readme"
}
